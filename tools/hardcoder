#!/usr/bin/env python3
"""
Usage:
    hardcoder <option> <inputfile> <outputfile>

Options:
    c   - Hardcode in C
    cxx - Hardcode in C++
"""
import argparse
import sys
from pathlib import Path

def create_valid_identifier(filename: str) -> str:
    if not filename:
        return "_"

    if filename[0].isdigit():
        filename = "_" + filename

    return "".join("_" if ch in ".- " else ch for ch in filename)


def generate_header(data: bytes, identifier: str, option: str) -> str:
    keyword = "const" if option == "c" else "constexpr"

    lines = []
    lines.append("/* Generated by hardcoder. Do not edit manually. */")
    lines.append(f"#ifndef {identifier}_H")
    lines.append(f"#define {identifier}_H")
    lines.append("")
    lines.append("/* Embedded data */")
    lines.append(f"{keyword} unsigned char {identifier}[] = {{")

    # 16 bytes per line, formatted as "0xNN"
    hex_bytes = [f"0x{b:02x}" for b in data]
    for i in range(0, len(hex_bytes), 16):
        chunk = hex_bytes[i:i + 16]
        line = "    " + ", ".join(chunk)
        if i + 16 < len(hex_bytes):
            line += ","
        lines.append(line)

    lines.append("};")
    lines.append("")
    lines.append("/* Size of the embedded data */")
    lines.append(f"{keyword} unsigned int {identifier}_size = {len(data)};")
    lines.append("")
    lines.append("#endif")
    lines.append("")

    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="hardcoder.py",
        description="Embed a binary file's contents into a C/C++ header file.",
        add_help=True,
    )
    parser.add_argument("option", help="c - Hardcode in C, cxx - Hardcode in C++")
    parser.add_argument("inputfile", help="Path to the input binary file")
    parser.add_argument("outputfile", help="Path to the generated header file")
    parser.add_argument(
        "-p", "--prefix",
        default="",
        help="Optional prefix to prepend to the generated variable/identifier names",
    )

    if len(sys.argv) < 4:
        parser.print_usage()
        print("Options:")
        print("\tc   - Hardcode in C")
        print("\tcxx - Hardcode in C++")
        return 1

    args = parser.parse_args()

    option = args.option.lower()
    if option not in ("c", "cxx"):
        print(f'Invalid option "{option}"', file=sys.stderr)
        return 1

    input_filepath = Path(args.inputfile)
    output_filepath = Path(args.outputfile)

    try:
        data = input_filepath.read_bytes()
    except OSError:
        print(f'Could not open file "{input_filepath}"', file=sys.stderr)
        return 1

    identifier = create_valid_identifier(input_filepath.name)
    if args.prefix:
        identifier = create_valid_identifier(args.prefix) + "_" + identifier
    header_text = generate_header(data, identifier, option)

    output_filepath.parent.mkdir(parents=True, exist_ok=True)

    output_filepath.write_text(header_text)

    return 0


if __name__ == "__main__":
    sys.exit(main())
